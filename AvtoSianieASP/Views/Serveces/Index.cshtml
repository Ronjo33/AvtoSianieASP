@model IEnumerable<AvtoSianieASP.Models.Servece>

@{
    ViewData["Title"] = "Услуги";
}

<div class="calendar-hero mb-5">
    <p class="eyebrow">AVTO SIANIE</p>
    <h1>Нашите услуги</h1>
    <p>Избери услуга и запази час директно от календара.</p>
</div>

@if (User.IsInRole("Admin"))
{
    <div class="mb-4">
        <a asp-action="Create" class="btn btn-danger btn-lg px-4">
            + Добави услуга
        </a>
    </div>
}

<div class="services-grid">
    @foreach (var item in Model)
    {
        <div class="service-card-red">

            <div class="service-image-wrapper">
                @if (!string.IsNullOrEmpty(item.Image))
                {
                    <img src="@item.Image" class="service-img" />
                }
                else
                {
                    <img src="/images/homeimg.jpg" class="service-img" />
                }
            </div>

            <div class="service-content">

                <h3>@item.DescSurves</h3>

                <div class="service-info">
                    <p>
                        <strong>Категория:</strong>
                        @item.Categories?.Name
                    </p>

                    <p>
                        <strong>Оборудване:</strong>
                        @item.Equipment
                    </p>

                    <p>
                        <strong>Времетраене:</strong>
                        @item.Duration мин.
                    </p>
                </div>

                <div class="service-bottom">
                    <div class="service-price">
                        €@item.Price.ToString("0.00")
                    </div>

                    <a asp-controller="Orders"
                       asp-action="Calendar"
                       asp-route-serveceId="@item.Id"
                       class="btn btn-red w-100">
                        Запази час
                    </a>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="admin-buttons mt-3">
                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </div>
                }

            </div>
        </div>
    }
</div>