@model IEnumerable<AvtoSianieASP.Models.Servece>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.KatNum)</th>
            <th>@Html.DisplayNameFor(model => model.DescSurves)</th>
            <th>Category</th>
            <th>@Html.DisplayNameFor(model => model.Equipment)</th>
            <th>@Html.DisplayNameFor(model => model.Duration)</th>
            <th>Image</th>
            <th>@Html.DisplayNameFor(model => model.Price)</th>
            <th>@Html.DisplayNameFor(model => model.DateOn)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.KatNum)</td>
                <td>@Html.DisplayFor(modelItem => item.DescSurves)</td>
                <td>@item.Categories.Name</td>
                <td>@Html.DisplayFor(modelItem => item.Equipment)</td>
                <td>@Html.DisplayFor(modelItem => item.Duration)</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Image))
                    {
                        <a href="@item.Image" target="_blank">
                            <img src="@item.Image"
                                 alt="Image"
                                 style="max-width: 100px; max-height: 100px; object-fit: cover; border-radius: 5px; border:1px solid #ccc;" />
                        </a>
                    }
                    else
                    {
                        <span>No Image</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Price)</td>
                <td>@item.DateOn.ToString("yyyy-MM-dd")</td>
                <td class="d-flex gap-1">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>