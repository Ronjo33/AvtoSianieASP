@model IEnumerable<AvtoSianieASP.Models.Servece>

@{
    ViewData["Title"] = "Услуги";
}

<div class="calendar-hero mb-4">
    <p class="eyebrow">Avto Sianie</p>
    <h1>Нашите услуги</h1>
    <p>Избери услуга и запази час директно от календара.</p>
</div>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-danger">Добави услуга</a>
    </p>
}

<div class="services-grid">
    @foreach (var item in Model)
    {
        <div class="service-card-red">
            @if (!string.IsNullOrEmpty(item.Image))
            {
                <img src="@item.Image" class="service-img" />
            }

            <h3>@item.DescSurves</h3>

            <p><strong>Категория:</strong> @item.Categories?.Name</p>
            <p><strong>Оборудване:</strong> @item.Equipment</p>
            <p><strong>Времетраене:</strong> @item.Duration</p>
            <p class="service-price">@item.Price лв.</p>

            <a asp-controller="Orders"
               asp-action="Calendar"
               asp-route-serveceId="@item.Id"
               class="btn btn-red">
                Запази час
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </div>
            }
        </div>
    }
</div>