@model AvtoSianieASP.Models.Order
@{
    ViewData["Title"] = "Календар";
    var hours = ViewData["Hours"] as List<string> ?? new List<string>();
    var busyHours = ViewData["BusyHours"] as List<string> ?? new List<string>();
}

<div class="calendar-hero mb-4">
    <p class="eyebrow">Резервации</p>
    <h1>Календар за часове</h1>
    <p>Избери дата и виж кои часове са свободни.</p>
</div>

<div class="calendar-card">
    <form asp-action="Calendar" method="get" class="calendar-date-box">
        <label>Избери дата</label>
        <input type="date"
               name="date"
               value="@Model.ReservationDate.ToString("yyyy-MM-dd")"
               onchange="this.form.submit()" />
    </form>

    <h3>Часове за @Model.ReservationDate.ToString("dd.MM.yyyy")</h3>

    <div class="calendar-time-grid">
        @foreach (var hour in hours)
        {
            var isBusy = busyHours.Contains(hour);

            <div class="calendar-time-card @(isBusy ? "busy" : "free")">
                <span class="time">@hour</span>

                @if (isBusy)
                {
                    <span class="status busy-text">Заето</span>
                }
                else
                {
                    <span class="status free-text">Свободно</span>

                    <a asp-action="Create"
                       asp-route-date="@Model.ReservationDate.ToString("yyyy-MM-dd")"
                       class="calendar-btn">
                        Запази
                    </a>
                }
            </div>
        }
    </div>
</div>