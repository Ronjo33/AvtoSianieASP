@model AvtoSianieASP.Models.Order
@{
    ViewData["Title"] = "Нова резервация";
    var hours = ViewData["Hours"] as List<string> ?? new List<string>();
    var busyHours = ViewData["BusyHours"] as List<string> ?? new List<string>();
}

<div class="booking-hero mb-4">
    <p class="eyebrow">Нова резервация</p>
    <h1>Запази час</h1>
    <p>Попълни данните и избери свободен час.</p>
</div>

<div class="booking-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="CustomerId" class="form-label"></label>
            <select asp-for="CustomerId" class="form-select dark-input" asp-items="ViewBag.CustomerId"></select>
        </div>

        <div class="mb-3">
            <label asp-for="ServeceId" class="form-label"></label>
            <select asp-for="ServeceId" class="form-select dark-input" asp-items="ViewBag.ServeceId"></select>
        </div>

        <div class="mb-3">
            <label asp-for="ReservationDate" class="form-label"></label>
            <input asp-for="ReservationDate" type="date" class="form-control dark-input" />
        </div>

        <label class="form-label">Час</label>
        <div class="booking-time-grid mb-3">
            @foreach (var hour in hours)
            {
                var isBusy = busyHours.Contains(hour);

                <label class="booking-time-chip @(isBusy ? "busy" : "")">
                    <input type="radio" name="ReservationTime" value="@hour" disabled="@isBusy" />
                    <span>@hour</span>
                </label>
            }
        </div>

        <span asp-validation-for="ReservationTime" class="text-danger"></span>

        <div class="mb-3">
            <label asp-for="Massage" class="form-label"></label>
            <textarea asp-for="Massage" class="form-control dark-input" rows="4"></textarea>
            <span asp-validation-for="Massage" class="text-danger"></span>
        </div>

        <button type="submit" class="booking-btn">Запази</button>
        <a asp-action="Calendar" class="booking-btn-outline ms-2">Календар</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}